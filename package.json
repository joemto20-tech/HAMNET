{
  "name": "ham-command-terminal",
  "version": "1.0.0",
  "description": "NVMP Companion / HAM Terminal",
  "main": "main.js",
  "author": "HAMNET",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.hamnet.nvmpcompanion",
    "productName": "NVMP Companion",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!node_modules/.cache/**"
    ],
    "extraMetadata": {
      "main": "main.js"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon_fixed.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NVMP Companion"
    }
  },
  "allowScripts": {
    "electron-winstaller@5.4.0": true
  }
}
