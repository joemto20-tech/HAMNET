{
  "name": "ham-command-terminal",
  "version": "1.0.0",
  "description": "NVMP Companion Terminal",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.nvmp.companion",
    "productName": "NVMP Companion",
    "artifactName": "${productName}-${version}.${ext}",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "server.js",
      "package.json",
      "public/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/NVMP_RadioTower.ico"
    },
    "nsis": {
      "installerIcon": "assets/NVMP_RadioTower.ico",
      "uninstallerIcon": "assets/NVMP_RadioTower.ico",
      "installerHeaderIcon": "assets/NVMP_RadioTower.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NVMP Companion"
    }
  }
}
